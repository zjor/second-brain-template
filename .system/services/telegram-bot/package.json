{
  "name": "telegram-brain-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node24 --out-dir dist --clean",
    "dev": "node --env-file=.env.local --import tsx src/index.ts",
    "start": "node --env-file=.env.local dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@deepgram/sdk": "^4.0.0",
    "@google/genai": "^1.0.0",
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.5.0",
    "grammy": "^1.31.0",
    "hono": "^4.6.0",
    "proper-lockfile": "^4.1.2",
    "telegramify-markdown": "^1.3.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
